# ============================================
# EXAMPLE ENVIRONMENT FILE
# ============================================
# Copy this to .env and update values as needed
# Or run 'make setup' to auto-generate

# ============================================
# DATABASE
# ============================================
# For Docker (local development):
DATABASE_URL=postgresql://coupon_user:coupon_pass@localhost:5432/coupon_db

# For Supabase (production):
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ============================================
# REDIS CACHE
# ============================================
# For Docker (local development):
REDIS_URL=redis://localhost:6379/0

# For production (Redis Cloud, AWS ElastiCache, etc.):
# REDIS_URL=rediss://:password@host:6379/0

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================
# STRIPE PAYMENT
# ============================================
# Test keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# AWS S3 (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ============================================
# EXTERNAL API (Optional)
# ============================================
EXTERNAL_API_KEY=

# ============================================
# APPLICATION
# ============================================
ENVIRONMENT=development
DEBUG=True
