            "body": {"mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"country_code\": \"+971\",\n  \"number\": \"501234567\",\n  \"password\": \"SecurePass123!\",\n  \"full_name\": \"John Doe\"\n}"}
          }
        },
        {
          "name": "Login (Unified)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]},
            "body": {"mode": "raw", "raw": "{\n  \"country_code\": \"+971\",\n  \"number\": \"501234567\",\n  \"password\": \"SecurePass123!\"\n}"}
          }
